{
  "name": "affiliate-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:stable": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "check": "tsc --noEmit && next lint",
    "safe-check": "bash scripts/safe-check.sh",
    "migrate": "supabase db push",
    "types": "supabase gen types typescript --project-id owvtfzxvirttrbcsiveg --schema public > src/types/supabase-generated.ts",
    "reset-cache": "rm -rf .next",
    "smoke": "next build && playwright test",
    "smoke:dev": "playwright test",
    "smoke:report": "playwright show-report",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@supabase/ssr": "^0.6.0",
    "@supabase/supabase-js": "^2.49.0",
    "@types/papaparse": "^5.5.2",
    "clsx": "^2.1.0",
    "heic2any": "^0.0.4",
    "next": "^15.3.0",
    "next-intl": "^4.13.0",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.0",
    "prettier": "^3.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^2.1.9"
  }
}
