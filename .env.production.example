# ─────────────────────────────────────────────────────────────────────────────
# .env.production.example — Vercel environment variable checklist
# Copy variable NAMES into Vercel dashboard → Project → Settings → Environment Variables
# NEVER put real values in this file — it is committed to git
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Source: supabase.com → your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Used for server-side admin operations that bypass RLS (never exposed to browser)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── App ───────────────────────────────────────────────────────────────────────

# Your production domain (used for referral link generation and email callbacks)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# WhatsApp contact number for wholesale order submission
# Format: country_code + number, no + or spaces (e.g. Morocco: 212XXXXXXXXX)
NEXT_PUBLIC_WHATSAPP_PHONE=212XXXXXXXXX

# ── Future — add when features are ready ─────────────────────────────────────

# ── Telegram product ingestion (module 053) ─────────────────────────────────
# Token du bot, fourni par @BotFather.
# TELEGRAM_BOT_TOKEN=
# Secret partagé du webhook (chaîne aléatoire ≥ 32 chars). Doit correspondre au
# secret_token passé à setWebhook côté Telegram. Vérifié en temps constant.
# TELEGRAM_WEBHOOK_SECRET=
# Username du bot (sans @) — affiché dans l'UI de liaison fournisseur.
# TELEGRAM_BOT_USERNAME=
# Clé API Anthropic — extraction IA (Haiku) de la fiche produit.
# ANTHROPIC_API_KEY=

# Sentry DSN (when error tracking is added)
# NEXT_PUBLIC_SENTRY_DSN=

# Resend API key (when transactional emails are added)
# RESEND_API_KEY=

# ── GitHub Actions secrets checklist ─────────────────────────────────────────
# Add these to: GitHub → repo → Settings → Secrets and variables → Actions
# NEXT_PUBLIC_SUPABASE_URL
# NEXT_PUBLIC_SUPABASE_ANON_KEY
# NEXT_PUBLIC_APP_URL
# NEXT_PUBLIC_WHATSAPP_PHONE
# CSV_IMAGE_ALLOWED_HOSTS=
