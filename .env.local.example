# ── Identifiants des comptes test pour les smoke tests Playwright ──────────────
# Copier ce fichier en `.env.local` (NON commité) et renseigner 1 compte test par rôle.
# Un rôle laissé vide est « skip » proprement : ses routes protégées ne seront PAS testées.
#
# Ces comptes servent UNIQUEMENT aux smoke tests locaux/pre-push.

SMOKE_AFFILIATE_EMAIL=
SMOKE_AFFILIATE_PASSWORD=

SMOKE_WHOLESALE_EMAIL=
SMOKE_WHOLESALE_PASSWORD=

SMOKE_SUPPLIER_EMAIL=
SMOKE_SUPPLIER_PASSWORD=

SMOKE_ADMIN_EMAIL=
SMOKE_ADMIN_PASSWORD=

# Optionnel : tester contre une autre URL (ex: preview déployée). Défaut http://localhost:3000
# SMOKE_BASE_URL=http://localhost:3000
